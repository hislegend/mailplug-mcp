# mailplug-mcp 환경 변수 예시 파일
# 실제 값은 .env 또는 macOS 키체인에 저장하세요. 이 파일은 git에 커밋해도 됩니다.

# ── 필수 ─────────────────────────────────────────────────────
# Mail Plug 메일 주소 (예: valla@crabs.ai)
MAILPLUG_EMAIL=

# ── 선택 ─────────────────────────────────────────────────────
# IMAP/SMTP 호스트. 비워두면 기본값(imap.mailplug.co.kr / smtp.mailplug.co.kr) 사용.
MAILPLUG_IMAP_HOST=
MAILPLUG_IMAP_PORT=993
MAILPLUG_SMTP_HOST=
MAILPLUG_SMTP_PORT=465

# 발신자 표시 이름 (예: "홍길동")
MAILPLUG_DISPLAY_NAME=

# 서명 정책: "mailplug" | "template" | "auto"
#   mailplug: Mail Plug에 등록된 기존 서명 HTML을 그대로 사용
#   template: 아래 MAILPLUG_SIGNATURE_* 값으로 표준 템플릿 자동 생성
#   auto: mailplug 우선, 없으면 template 폴백 (기본값)
MAILPLUG_SIGNATURE_MODE=auto

# template 모드에서 사용할 서명 정보
MAILPLUG_SIGNATURE_NAME=
MAILPLUG_SIGNATURE_TITLE=
MAILPLUG_SIGNATURE_COMPANY=
MAILPLUG_SIGNATURE_PHONE=
MAILPLUG_SIGNATURE_WEBSITE=

# ── 비밀번호 ─────────────────────────────────────────────────
# 비밀번호는 절대 이 파일에 적지 마세요. 다음 명령으로 키체인에 저장하세요:
#   mailplug-mcp-setup
# (혹은) 비밀번호를 환경변수로 강제로 넣고 싶으면 아래에 입력 (개발용 테스트만 권장):
# MAILPLUG_APP_PASSWORD=
